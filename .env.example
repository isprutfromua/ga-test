# Application
PORT=8080
BASE_URL=http://localhost:8080
STATIC_DIR=./static
MIGRATIONS_PATH=./internal/db/migrations
API_KEY=dev-api-key-change-in-production

# HTTP timeouts
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
DOCKER_DATABASE_URL=postgres://postgres:postgres@db:5432/postgres?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
DOCKER_REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=
GITHUB_CACHE_TTL=10m

# GitHub
# Strongly recommended for production and higher GitHub API limits
GITHUB_TOKEN=
GITHUB_BASE_URL=https://api.github.com

# SMTP (Mailpit defaults for local development)
SMTP_HOST=localhost
DOCKER_SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=false

# Background scanner
SCANNER_INTERVAL=5m
SCANNER_WORKERS=5
